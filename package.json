{
  "name": "chrome2code",
  "version": "0.1.0",
  "private": true,
  "description": "Capture browser errors and generate fix prompts for Claude Code",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:extension": "npm run build -w packages/extension",
    "build:cli": "npm run build -w packages/cli",
    "dev:extension": "npm run dev -w packages/extension",
    "test": "npm run test --workspaces",
    "lint": "tsc --noEmit --project tsconfig.base.json"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
